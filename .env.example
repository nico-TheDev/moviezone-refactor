# Server-only (never expose via VITE_)
TMDB_BEARER_TOKEN=your_read_access_token_here
TMDB_API_KEY=your_api_key_here

# Optional: distributed rate limiting (required on Vercel serverless)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Public app URL used for TMDB OAuth redirect (no trailing slash).
# Example: https://moviezone.example.com
# VITE_APP_URL=

# BFF server port (dev)
# PORT=3001
